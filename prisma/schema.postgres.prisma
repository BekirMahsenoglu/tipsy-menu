// Vercel için Postgres şeması
// Kullanım: Bu dosyayı schema.prisma olarak kopyalayın veya
// prisma/schema.prisma içinde provider = "postgresql" yapın.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  nameTr      String
  nameEn      String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]

  @@index([order])
}

model Product {
  id          String   @id @default(cuid())
  nameTr      String
  nameEn      String
  descriptionTr String?
  descriptionEn String?
  price       Float
  imageUrl    String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([inStock])
}

model Order {
  id           String   @id @default(cuid())
  tableNumber  String
  items       String   // JSON: [{ productId, nameTr, nameEn, quantity, unitPrice }]
  totalPrice  Float
  status      String   @default("pending") // pending | completed
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}
